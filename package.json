{
  "name": "vleb-workspace",
  "productName": "V-LEB Workspace",
  "description": "V-LEB Workspace - Multi-Service Management Platform",
  "license": "MIT",
  "private": true,
  "version": "1.0.0",
  "author": "V-LEB Technology",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env DEV_ENV=true electron .\"",
    "dev:vite": "vite",
    "dev:electron": "cross-env DEV_ENV=true electron .",
    "build": "vite build",
    "build:production": "dotenv -e .env.production -- vite build",
    "preview": "vite preview",
    "dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build:production && electron-builder",
    "dist:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build:production && electron-builder --win",
    "dist:nsis": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false npm run build:production && electron-builder --win nsis",
    "release": "node scripts/pre-release.mjs"
  },
  "build": {
    "appId": "com.vleb.workspace",
    "productName": "V-LEB Workspace",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/keytar/**/*",
      "node_modules/sharp/**/*"
    ],
    "nodeGypRebuild": false,
    "buildDependenciesFromSource": false,
    "publish": {
      "provider": "generic",
      "url": "https://leb.visualabs.id/downloads/workspace"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "sign": null,
      "signingHashAlgorithms": []
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "V-LEB Workspace",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    }
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tailwindcss/vite": "^4.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.2",
    "electron": "^34.0.1",
    "electron-builder": "^25.1.8",
    "svelte": "^5.19.5",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.11",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "dexie": "^4.3.0",
    "keytar": "^7.9.0",
    "lucide-svelte": "^0.563.0",
    "sharp": "^0.34.5",
    "svelte-dnd-action": "^0.9.69",
    "uuid": "^13.0.0"
  }
}