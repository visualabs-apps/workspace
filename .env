# Development API URLs (local)
VITE_API_BASE_URL=http://localhost:2024/api
VITE_BACKEND_URL=http://localhost:2024

# Note: Production URLs are in .env.production file
# Used by build:production script

# ── GitHub Auto-Update (Public Repo) ──────────────────────────────────────
